# MarketPulse India — environment variables
# Copy this file to `.env` (never commit `.env`) and fill in real values.

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_ENV=local                       # local | dev | staging | prod
APP_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
APP_TZ=Asia/Kolkata                 # always IST; do not change

# ----------------------------------------------------------------------------
# OpenAI (this project is OpenAI-only — no Anthropic key)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-replace-me
OPENAI_ORG_ID=                      # optional
LLM_STRONG_MODEL=gpt-4o
LLM_FAST_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ----------------------------------------------------------------------------
# Database (Postgres)
# ----------------------------------------------------------------------------
POSTGRES_USER=marketpulse
POSTGRES_PASSWORD=marketpulse
POSTGRES_DB=marketpulse
DATABASE_URL=postgresql+asyncpg://marketpulse:marketpulse@localhost:5432/marketpulse
# Sync URL used by Alembic offline mode only.
DATABASE_SYNC_URL=postgresql+psycopg://marketpulse:marketpulse@localhost:5432/marketpulse

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# Market data providers
# ----------------------------------------------------------------------------
NSE_API_BASE_URL=https://www.nseindia.com
BSE_API_BASE_URL=https://api.bseindia.com
# Optional paid providers
KITE_API_KEY=
KITE_API_SECRET=
ALPHA_VANTAGE_API_KEY=

# ----------------------------------------------------------------------------
# AWS (used by deploy + lambdas; leave blank for local dev)
# ----------------------------------------------------------------------------
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=
AWS_ECR_REPO=marketpulse-backend
S3_LAMBDA_BUCKET=

# NSE poller Lambda environment (also used by infra/polling_stack.py at synth)
FASTAPI_WEBHOOK_URL=https://your-api-domain/api/webhook/announcement
NSE_POLL_STATE_TABLE=nse-poll-state
NSE_SYMBOLS_TABLE=nse-watched-symbols
S3_BUCKET=marketpulse-india-filings

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=marketpulse-india
SENTRY_DSN=

# ----------------------------------------------------------------------------
# Authentication (JWT)
# ----------------------------------------------------------------------------
# Must be at least 32 random characters in production.
JWT_SECRET_KEY=change-me-in-production-use-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ----------------------------------------------------------------------------
# Webhook security
# ----------------------------------------------------------------------------
WEBHOOK_SECRET=marketpulse-webhook-secret-2026

# ----------------------------------------------------------------------------
# Rate limiting
# ----------------------------------------------------------------------------
RATE_LIMIT_ANALYSES_PER_DAY=100

# ----------------------------------------------------------------------------
# LangSmith tracing (optional)
# ----------------------------------------------------------------------------
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=marketpulse-india

# ----------------------------------------------------------------------------
# Alert dispatcher  (backend/alerts/dispatcher.py)
# Leave blank to disable that channel — the dispatcher skips silently.
# ----------------------------------------------------------------------------

# WhatsApp (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=           # Meta System User permanent access token
WHATSAPP_PHONE_NUMBER_ID=        # WABA phone-number ID from Meta dashboard
WHATSAPP_TO_NUMBER=              # Recipient E.164 number  e.g. +919876543210

# Telegram Bot API
TELEGRAM_BOT_TOKEN=              # Token from @BotFather
TELEGRAM_CHAT_ID=                # @channelname or numeric chat ID

# SMS via AWS SNS (uses AWS_REGION / AWS_ACCESS_KEY_ID from the AWS block above)
ALERT_SMS_NUMBER=                # Recipient E.164 number  e.g. +919876543210

# ----------------------------------------------------------------------------
# Compliance
# ----------------------------------------------------------------------------
# The disclaimer text is hardcoded in backend/config.py — do not override
# from env. This flag only controls whether the app refuses to start if the
# disclaimer module is missing.
REQUIRE_SEBI_DISCLAIMER=true
